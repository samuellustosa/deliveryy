generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String?  @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  stores    Store[]
}

model Store {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?  // FOTO DE PERFIL
  coverUrl    String?  // BANNER GRANDE DO NAV
  niche       String   @default("gastronomia") // acaiteria, pizzaria, etc
  phone       String   @unique
  password    String
  address     String?
  deliveryFee Float    @default(0)

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  categories   Category[]
  products     Product[]
  orders       Order[]
  banners      Banner[]
  optionGroups OptionGroup[] // GRUPOS DE ADICIONAIS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OptionGroup {
  id          String   @id @default(uuid())
  name        String   // Ex: "Escolha as Bordas", "Adicionais"
  minOptions  Int      @default(0)
  maxOptions  Int      @default(1)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  products    Product[] 
  options     Option[]

  @@index([storeId])
}

model Option {
  id            String      @id @default(uuid())
  name          String
  price         Float       @default(0)
  optionGroupId String
  group         OptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)

  @@index([optionGroupId])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  order     Int       @default(0)
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products  Product[]

  @@index([storeId])
}

model Product {
  id           String        @id @default(uuid())
  name         String
  description  String?
  price        Float
  imageUrl     String?
  isActive     Boolean       @default(true)
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  storeId      String
  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  optionGroups OptionGroup[] // RELAÇÃO COM ADICIONAIS
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([storeId])
  @@index([categoryId])
}

model Order {
  id            String      @id @default(uuid())
  customerName  String
  customerPhone String
  type          String      
  zipCode       String?
  street        String?
  number        String?
  complement    String?
  reference     String?
  city          String?
  state         String?
  deliveryFee   Float       @default(0)
  address       String      
  total         Float
  status        OrderStatus @default(PENDING)
  
  storeId       String
  store         Store       @relation(fields: [storeId], references: [id])
  
  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model Banner {
  id        String   @id @default(uuid())
  imageUrl  String
  link      String?
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([storeId])
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  price     Float
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}